# Copy this to .env and fill in every value. Never commit .env to git.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=talentlink
POSTGRES_USER=talentlink_user
POSTGRES_PASSWORD=CHANGE_ME

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── App ───────────────────────────────────────────────────────────────────────
# "development" → skips SMTP guard, returns reset token in API response
# "production"  → requires SMTP vars below, never returns reset token
APP_ENV=production
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_PROXY=false

# ── SMTP (required when APP_ENV=production) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3000

# ── Client build ──────────────────────────────────────────────────────────────
# URL the BROWSER uses to reach the API. If you change this, rebuild the client.
VITE_API_URL=http://localhost:8000/api
